@@ -0,0 +1,42 @@
+import pytest
+
+from fizzbuzz import fizzbuzz, play_fizzbuzz
+
+
+class TestFizzbuzz:
+    @pytest.mark.parametrize(
+        ("n", "expected"),
+        [
+            (1, "1"),
+            (2, "2"),
+            (3, "Fizz"),
+            (5, "Buzz"),
+            (6, "Fizz"),
+            (10, "Buzz"),
+            (15, "FizzBuzz"),
+            (30, "FizzBuzz"),
+            (97, "97"),
+        ],
+    )
+    def test_fizzbuzz(self, n: int, expected: str) -> None:
+        assert fizzbuzz(n) == expected
+
+
+class TestPlayFizzbuzz:
+    def test_length(self) -> None:
+        result = play_fizzbuzz(1, 100)
+        assert len(result) == 100
+
+    def test_first_element(self) -> None:
+        assert play_fizzbuzz()[0] == "1"
+
+    def test_last_element(self) -> None:
+        assert play_fizzbuzz()[-1] == "Buzz"
+
+    def test_contains_fizzbuzz_at_15(self) -> None:
+        result = play_fizzbuzz()
+        assert result[14] == "FizzBuzz"
+
+    def test_custom_range(self) -> None:
+        result = play_fizzbuzz(14, 16)
+        assert result == ["14", "FizzBuzz", "16"]
