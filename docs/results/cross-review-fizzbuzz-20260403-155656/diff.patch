+def fizzbuzz(n: int) -> str:
+    """Return FizzBuzz result for a given number.
+
+    Args:
+        n: A positive integer.
+
+    Returns:
+        'FizzBuzz' if divisible by both 3 and 5,
+        'Fizz' if divisible by 3,
+        'Buzz' if divisible by 5,
+        the number as a string otherwise.
+    """
+    if n % 15 == 0:
+        return "FizzBuzz"
+    if n % 3 == 0:
+        return "Fizz"
+    if n % 5 == 0:
+        return "Buzz"
+    return str(n)
+
+
+def play_fizzbuzz(start: int = 1, end: int = 100) -> list[str]:
+    """Play FizzBuzz from start to end inclusive.
+
+    Args:
+        start: First number in the range.
+        end: Last number in the range.
+
+    Returns:
+        List of FizzBuzz results.
+    """
+    return [fizzbuzz(i) for i in range(start, end + 1)]
+
+
+if __name__ == "__main__":
+    for result in play_fizzbuzz():
+        print(result)
diff --git a/test_fizzbuzz.py b/test_fizzbuzz.py
